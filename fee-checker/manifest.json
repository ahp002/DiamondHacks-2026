{
  "manifest_version": 3,
  "name": "Fee Checker",
  "version": "1.0",
  "description": "See the real cost of any transfer — fees, FX spread, and total before you send.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.frankfurter.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.paypal.com/*",
        "https://venmo.com/*",
        "https://wise.com/*",
        "https://www.westernunion.com/*",
        "https://www.remitly.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
